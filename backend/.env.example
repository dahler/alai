# Application
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/alai

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# Microsoft OAuth
# Register your app at https://portal.azure.com → App registrations → Authentication
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
# IMPORTANT: This must point to the BACKEND callback endpoint, NOT the frontend URL.
# The backend exchanges the OAuth code for a token, then redirects to the frontend.
# This value must exactly match the redirect URI registered in your Azure app registration.
# Production example: MICROSOFT_REDIRECT_URI=https://api.yourdomain.com/api/auth/callback
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=gemma3:4b
OLLAMA_VISION_MODEL=qwen2.5vl
OLLAMA_ROUTER_MODEL=gemma3:1b
OLLAMA_AGENT_MODEL=qwen2.5:14b
# IMPORTANT: OLLAMA_EMBEDDING_MODEL and RAG_EMBEDDING_DIM must stay paired to
# the model's real output dimension AND the vector() column size in the DB
# (see alembic migration 010, currently vector(1024)):
#   bge-m3           -> RAG_EMBEDDING_DIM=1024  (multilingual; best Indonesian)
#   nomic-embed-text -> RAG_EMBEDDING_DIM=768   (English-centric)
# A mismatch makes every embedding insert fail and marks the model unavailable.
# Changing the pair requires a migration to resize the columns + a full re-embed.
OLLAMA_EMBEDDING_MODEL=bge-m3

# Tavily (Web Search) - Get API key from https://tavily.com
TAVILY_API_KEY=your-tavily-api-key

# RAG Settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
# Must match OLLAMA_EMBEDDING_MODEL's output dim and the DB vector() column
# (see note above). bge-m3=1024, nomic-embed-text=768.
RAG_EMBEDDING_DIM=1024

# CORS
# Also used to build the redirect URL back to the frontend after OAuth login.
# Production example: CORS_ORIGINS=["https://app.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]
